# ══════════════════════════════════════════
# Agent Guardian — Environment Variables
# Copy to apps/api/.env and apps/web/.env
# ══════════════════════════════════════════

# ── Server ────────────────────────────────
NODE_ENV=development
PORT=3001

# ── Database (PostgreSQL) ─────────────────
DATABASE_URL=postgresql://agentguardian:agentguardian_dev@localhost:5432/agentguardian

# ── Redis ─────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth0 ─────────────────────────────────
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=https://api.agentguardian.com
AUTH0_CLIENT_ID=<spa-client-id>
AUTH0_M2M_CLIENT_ID=<backend-m2m-client-id>
AUTH0_M2M_CLIENT_SECRET=<backend-m2m-client-secret>

# ── Auth0 Token Vault ─────────────────────
AUTH0_TOKEN_VAULT_BASE_URL=https://your-tenant.auth0.com

# ── Auth0 Agent M2M ──────────────────────
AGENT_AUTH0_CLIENT_ID=<agent-m2m-client-id>
AGENT_AUTH0_CLIENT_SECRET=<agent-m2m-client-secret>
# Development-only explicit user binding for the demo agent when the M2M token
# does not carry https://agentguardian.com/userId.
AGENT_ACTING_USER_EMAIL=<dashboard-user-email>
# AGENT_ACTING_AUTH0_USER_ID=auth0|example-user-id

# ── Frontend URL (CORS + OAuth redirect) ──
FRONTEND_URL=http://localhost:5173

# ── Web Push (VAPID) ─────────────────────
VAPID_PUBLIC_KEY=<vapid-public-key>
VAPID_PRIVATE_KEY=<vapid-private-key>

# ── AI / LLM (OpenRouter) ────────────────
OPENROUTER_API_KEY=<openrouter-api-key>
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Frontend (.env for Vite) ──────────────
VITE_AUTH0_DOMAIN=your-tenant.auth0.com
VITE_AUTH0_CLIENT_ID=<spa-client-id>
VITE_AUTH0_AUDIENCE=https://api.agentguardian.com
VITE_AUTH0_REDIRECT_URI=http://localhost:5173/callback
VITE_API_BASE_URL=http://localhost:3001
VITE_SOCKET_URL=http://localhost:3001
VITE_VAPID_PUBLIC_KEY=<vapid-public-key>
